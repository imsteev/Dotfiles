# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = Stephen Chung
	email = INSERT_EMAIL
[pager]
	branch = false
[alias]
	br = branch
	co = checkout
	cob = checkout -b
	ec = commit --allow-empty --no-verify
[fetch]
	prune = true
[rerere]
	enabled = true
[credential]
	helper = osxkeychain
